gantt
    title Project Schedule
    dateFormat YYYY-MM-DD
    section Planning
        Requirements : a1, 2024-01-01, 30d
        Design       : a2, after a1, 20d
    section Development
        Implementation : b1, after a2, 60d
        Testing        : b2, after b1, 30d
    section Release
        Deployment : c1, after b2, 10d
