///|
/// Renderers for unwrap candidate plan output.

///|
/// Render as Markdown.
pub fn render_markdown(plan : UnwrapPlanJSON) -> String {
  let buf = StringBuilder::new()
  buf.write_string("# Unwrap Candidates\n\n")
  buf.write_string("Generated by `indexion plan unwrap`\n\n")
  buf.write_string(
    "Wrapper functions that can be removed by replacing callers with direct calls to the delegate.\n\n",
  )
  // Configuration
  buf.write_string("## Configuration\n\n")
  buf.write_string("- **Directory**: `" + plan.config.target_dir + "`\n")
  if plan.config.includes.length() > 0 {
    buf.write_string("- **Includes**: ")
    for i, inc in plan.config.includes {
      if i > 0 {
        buf.write_string(", ")
      }
      buf.write_string("`" + inc + "`")
    }
    buf.write_string("\n")
  }
  if plan.config.excludes.length() > 0 {
    buf.write_string("- **Excludes**: ")
    for i, exc in plan.config.excludes {
      if i > 0 {
        buf.write_string(", ")
      }
      buf.write_string("`" + exc + "`")
    }
    buf.write_string("\n")
  }
  buf.write_string("\n")
  // Summary
  if plan.candidates.length() == 0 {
    buf.write_string("## Result\n\n")
    buf.write_string("No wrappers to unwrap.\n")
    return buf.to_string()
  }
  buf.write_string(
    "Found **" +
    plan.candidates.length().to_string() +
    "** wrappers to unwrap.\n\n",
  )
  buf.write_string("---\n\n")
  // Group by file
  let file_groups : Array[(String, Array[UnwrapEntry])] = []
  let file_index : Map[String, Int] = {}
  for entry in plan.candidates {
    match file_index.get(entry.file) {
      Some(idx) => file_groups[idx].1.push(entry)
      None => {
        file_index.set(entry.file, file_groups.length())
        file_groups.push((entry.file, [entry]))
      }
    }
  }
  for group in file_groups {
    let (file, entries) = group
    buf.write_string("## `" + file + "`\n\n")
    for entry in entries {
      buf.write_string(
        "### L" + entry.line.to_string() + ": " + entry.name + "\n\n",
      )
      buf.write_string("- **Delegates to**: `" + entry.delegate_target + "`\n")
      if entry.params.length() > 0 {
        buf.write_string("- **Parameters**: ")
        for i, p in entry.params {
          if i > 0 {
            buf.write_string(", ")
          }
          buf.write_string("`" + p + "`")
        }
        if entry.all_forwarded {
          buf.write_string(" -- all forwarded\n")
        } else {
          buf.write_string(" -- partially forwarded\n")
        }
      } else {
        buf.write_string("- **Parameters**: none\n")
      }
      buf.write_string(
        "- **Action**: Replace callers with `" +
        entry.delegate_target +
        "`, then delete\n",
      )
      buf.write_string("\n")
    }
  }
  buf.to_string()
}

///|
/// Render as JSON string.
pub fn render_json(plan : UnwrapPlanJSON) -> String {
  plan.to_json().stringify(indent=2)
}

///|
/// Render as plain text.
pub fn render_text(plan : UnwrapPlanJSON) -> String {
  let buf = StringBuilder::new()
  buf.write_string("UNWRAP CANDIDATES\n")
  buf.write_string("=================\n\n")
  buf.write_string("Directory: " + plan.config.target_dir + "\n")
  buf.write_string(
    "Wrappers to unwrap: " + plan.candidates.length().to_string() + "\n\n",
  )
  if plan.candidates.length() == 0 {
    buf.write_string("No wrappers to unwrap.\n")
    return buf.to_string()
  }
  for entry in plan.candidates {
    buf.write_string(
      entry.file +
      ":" +
      entry.line.to_string() +
      " " +
      entry.name +
      " -> " +
      entry.delegate_target,
    )
    if entry.all_forwarded {
      buf.write_string(" (all forwarded)")
    } else {
      buf.write_string(" (partial)")
    }
    buf.write_string("\n")
  }
  buf.to_string()
}
