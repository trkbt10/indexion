///|
/// Renderers for converting RefactorPlanJSON to various output formats.

///|
/// Render as Markdown.
pub fn render_markdown(plan : RefactorPlanJSON) -> String {
  let buf = StringBuilder::new()
  buf.write_string("# Refactoring Plan\n\n")
  buf.write_string("Generated by `indexion plan refactor`\n\n")
  // Configuration section
  buf.write_string("## Configuration\n\n")
  buf.write_string("- **Directory**: `" + plan.config.target_dir + "`\n")
  buf.write_string(
    "- **Threshold**: " + @common.format_percent(plan.config.threshold) + "\n",
  )
  buf.write_string("- **Strategy**: " + plan.config.strategy + "\n")
  if plan.config.includes.length() > 0 {
    buf.write_string("- **Includes**: ")
    for i, inc in plan.config.includes {
      if i > 0 {
        buf.write_string(", ")
      }
      buf.write_string("`" + inc + "`")
    }
    buf.write_string("\n")
  }
  if plan.config.excludes.length() > 0 {
    buf.write_string("- **Excludes**: ")
    for i, exc in plan.config.excludes {
      if i > 0 {
        buf.write_string(", ")
      }
      buf.write_string("`" + exc + "`")
    }
    buf.write_string("\n")
  }
  buf.write_string("\n")
  // No clusters case
  if plan.clusters.length() == 0 {
    buf.write_string("## Result\n\n")
    buf.write_string("No similar file groups found above threshold.\n")
    return buf.to_string()
  }
  // Summary section
  buf.write_string("## Summary\n\n")
  buf.write_string(
    "Found **" +
    plan.summary.total_clusters.to_string() +
    "** groups of similar files.\n\n",
  )
  buf.write_string("---\n\n")
  buf.write_string("## Refactoring Suggestions\n\n")
  // Render each cluster
  for i, cluster in plan.clusters {
    let max_sim = if cluster.pairs.length() > 0 {
      @common.format_percent(cluster.pairs[0].similarity)
    } else {
      "N/A"
    }
    buf.write_string(
      "### Group " +
      cluster.group_id.to_string() +
      " (max: " +
      max_sim +
      ")\n\n",
    )
    // Files
    buf.write_string("**Files:**\n")
    for file in cluster.files {
      buf.write_string("- `" + file + "`\n")
    }
    buf.write_string("\n")
    // Top similar pairs with excerpts (show top 3)
    buf.write_string("**Similar Excerpts:**\n\n")
    let max_excerpts = if cluster.pairs.length() < 3 {
      cluster.pairs.length()
    } else {
      3
    }
    for idx = 0; idx < max_excerpts; idx = idx + 1 {
      let pair = cluster.pairs[idx]
      buf.write_string(
        "**" +
        @common.format_percent(pair.similarity) +
        "** `" +
        pair.file1 +
        "` ↔ `" +
        pair.file2 +
        "`\n\n",
      )
      if pair.preview1.length() > 0 {
        buf.write_string("> **" + pair.file1 + ":**\n")
        buf.write_string("> " + escape_blockquote(pair.preview1) + "\n\n")
      }
      if pair.preview2.length() > 0 {
        buf.write_string("> **" + pair.file2 + ":**\n")
        buf.write_string("> " + escape_blockquote(pair.preview2) + "\n\n")
      }
    }
    // Similarity matrix (compact)
    if cluster.pairs.length() > 3 {
      buf.write_string("**All Pairs:**\n")
      buf.write_string("| File 1 | File 2 | Similarity |\n")
      buf.write_string("|--------|--------|------------|\n")
      for pair in cluster.pairs {
        buf.write_string(
          "| `" +
          pair.file1 +
          "` | `" +
          pair.file2 +
          "` | " +
          @common.format_percent(pair.similarity) +
          " |\n",
        )
      }
      buf.write_string("\n")
    }
    // Duplicate code blocks
    if cluster.duplicates.length() > 0 {
      buf.write_string("**Duplicate Code Blocks:**\n\n")
      // Group duplicates by file pair
      let mut current_pair = ""
      let mut dup_count = 0
      for dup in cluster.duplicates {
        let pair_key = dup.file1 + ":" + dup.file2
        if pair_key != current_pair {
          current_pair = pair_key
          dup_count = 0
          buf.write_string(
            "Between `" + dup.file1 + "` and `" + dup.file2 + "`:\n\n",
          )
        }
        if dup_count < 3 {
          let func_label = match dup.func_name {
            Some(name) => " (function `" + name + "`)"
            None => ""
          }
          buf.write_string(
            "- **" +
            dup.line_count.to_string() +
            " lines**" +
            func_label +
            " at `" +
            dup.file1 +
            ":" +
            dup.start_line1.to_string() +
            "` / `" +
            dup.file2 +
            ":" +
            dup.start_line2.to_string() +
            "`\n",
          )
          buf.write_string("  ```\n")
          let preview_lines = @common.split_lines(dup.preview)
          for line in preview_lines {
            buf.write_string("  " + line + "\n")
          }
          if dup.line_count > 3 {
            buf.write_string(
              "  // ... " + (dup.line_count - 3).to_string() + " more lines\n",
            )
          }
          buf.write_string("  ```\n")
          dup_count = dup_count + 1
        }
      }
      buf.write_string("\n")
    }
    // Suggested actions
    buf.write_string("**Suggested Actions:**\n\n")
    if cluster.duplicates.length() > 0 &&
      cluster.suggestions.shared_module.length() > 0 {
      buf.write_string(
        "1. **Extract shared code** to `" +
        cluster.suggestions.shared_module +
        "`\n",
      )
      if cluster.suggestions.functions_to_extract.length() > 0 {
        buf.write_string("   - Functions to extract: ")
        for k, name in cluster.suggestions.functions_to_extract {
          if k > 0 {
            buf.write_string(", ")
          }
          buf.write_string("`" + name + "`")
        }
        buf.write_string("\n")
      }
      buf.write_string(
        "2. **Update imports** in affected files to use shared module\n",
      )
      buf.write_string("3. **Remove duplicate definitions** from:\n")
      for file in cluster.suggestions.affected_files {
        buf.write_string("   - `" + file + "`\n")
      }
      buf.write_string("4. **Run tests** to verify refactoring\n")
    } else {
      buf.write_string("- [ ] Review files for duplicated code patterns\n")
      buf.write_string("- [ ] Consider extracting common logic\n")
      buf.write_string("- [ ] Verify tests pass after changes\n")
    }
    buf.write_string("\n")
    if i < plan.clusters.length() - 1 {
      buf.write_string("---\n\n")
    }
  }
  // Function-level duplicates (same-file and cross-file)
  if plan.function_duplicates.length() > 0 {
    buf.write_string("---\n\n")
    buf.write_string("## Function-Level Duplicates\n\n")
    buf.write_string(
      "Structurally similar functions detected (including same-file):\n\n",
    )
    buf.write_string(
      "| Function 1 | File 1 | Function 2 | File 2 | Similarity |\n",
    )
    buf.write_string("|---|---|---|---|---|\n")
    let max_func_dups = 30
    let mut func_dup_count = 0
    for dup in plan.function_duplicates {
      if func_dup_count >= max_func_dups {
        break
      }
      buf.write_string(
        "| `" +
        dup.func1 +
        "` | `" +
        dup.file1 +
        "` | `" +
        dup.func2 +
        "` | `" +
        dup.file2 +
        "` | " +
        @common.format_percent(dup.similarity) +
        " |\n",
      )
      func_dup_count += 1
    }
    buf.write_string("\n")
    // Show file locations for same-file duplicates
    let same_file_dups : Array[FunctionDuplicate] = []
    for dup in plan.function_duplicates {
      if dup.same_file {
        same_file_dups.push(dup)
      }
    }
    if same_file_dups.length() > 0 {
      buf.write_string(
        "**Same-file duplicates** (extract to shared function with parameter):\n\n",
      )
      for dup in same_file_dups {
        buf.write_string(
          "- `" +
          dup.func1 +
          "` ≈ `" +
          dup.func2 +
          "` in `" +
          dup.file1 +
          "` (" +
          @common.format_percent(dup.similarity) +
          ")\n",
        )
      }
      buf.write_string("\n")
    }
  }
  buf.to_string()
}

///|
/// Render as JSON string.
pub fn render_json(plan : RefactorPlanJSON) -> String {
  plan.to_json().stringify(indent=2)
}

///|
/// Render as plain text.
pub fn render_text(plan : RefactorPlanJSON) -> String {
  let buf = StringBuilder::new()
  buf.write_string("REFACTORING PLAN\n")
  buf.write_string("================\n\n")
  buf.write_string("Directory: " + plan.config.target_dir + "\n")
  buf.write_string(
    "Threshold: " + @common.format_percent(plan.config.threshold) + "\n",
  )
  buf.write_string("Strategy: " + plan.config.strategy + "\n")
  buf.write_string("\n")
  if plan.clusters.length() == 0 {
    buf.write_string("No similar file groups found.\n")
    return buf.to_string()
  }
  buf.write_string(
    "Found " + plan.summary.total_clusters.to_string() + " groups:\n\n",
  )
  for cluster in plan.clusters {
    buf.write_string("Group " + cluster.group_id.to_string() + ":\n")
    for file in cluster.files {
      buf.write_string("  - " + file + "\n")
    }
    if cluster.pairs.length() > 0 {
      buf.write_string("  Similarities:\n")
      for pair in cluster.pairs {
        buf.write_string(
          "    " +
          pair.file1 +
          " <-> " +
          pair.file2 +
          ": " +
          @common.format_percent(pair.similarity) +
          "\n",
        )
      }
    }
    if cluster.suggestions.shared_module.length() > 0 {
      buf.write_string(
        "  Suggested module: " + cluster.suggestions.shared_module + "\n",
      )
    }
    buf.write_string("\n")
  }
  buf.to_string()
}

// Helper functions

///|
/// Escape text for markdown blockquote (replace newlines with blockquote continuation).
fn escape_blockquote(text : String) -> String {
  let chars = text.to_array()
  let result : Array[Char] = []
  for c in chars {
    if c == '\n' {
      result.push('\n')
      result.push('>')
      result.push(' ')
    } else {
      result.push(c)
    }
  }
  String::from_array(result)
}

// format_percent, split_lines: use @common (SoT)
