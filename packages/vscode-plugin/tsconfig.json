{
  "compilerOptions": {
    "target": "es2024",
    "module": "ESNext",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@indexion/api-client": ["../api-client/src/index.ts"]
    },
    "jsx": "react-jsx",
    "declaration": true,
    "outDir": "dist",
    "types": ["node", "vitest/globals", "vite/client", "./src/webview/vscode-elements.d.ts"]
  },
  "include": ["src/**/*", "spec/**/*"],
  "exclude": ["src/webview/**/*", "src/e2e/**/*"]
}
