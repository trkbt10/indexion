{
  "compilerOptions": {
    "target": "es2024",
    "module": "ESNext",
    "lib": ["ES2024", "DOM"],
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "paths": {
      "@indexion/kgf-tokenizer": ["../kgf-tokenizer/src/index.ts"]
    }
  },
  "include": ["src/**/*"]
}
