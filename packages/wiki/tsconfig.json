{
  "compilerOptions": {
    "target": "es2024",
    "module": "ESNext",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "paths": {
      "@indexion/api-client": ["../api-client/src/index.ts"],
      "@indexion/api-client/react": ["../api-client/src/react.ts"],
      "@indexion/kgf-tokenizer": ["../kgf-tokenizer/src/index.ts"],
      "@indexion/mermaid-viewer": ["../mermaid-viewer/src/index.ts"],
      "@indexion/syntax-highlight": ["../syntax-highlight/src/index.ts"]
    }
  },
  "include": ["src/client/**/*"],
  "exclude": ["node_modules"]
}
